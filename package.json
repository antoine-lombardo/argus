{
  "name": "argus",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start --dev-client --localhost",
    "start:device": "expo start --dev-client",
    "android": "REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo run:android",
    "ios": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:ios",
    "android:no-bundler": "REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo run:android --no-bundler",
    "ios:no-bundler": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:ios --no-bundler",
    "web": "expo start --web",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset tag"
  },
  "dependencies": {
    "@argus-tv/plugin-sdk": "^0.1.1",
    "@expo/vector-icons": "^15.0.2",
    "expo": "~57.0.6",
    "expo-build-properties": "~57.0.5",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.7",
    "expo-video": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "npm:react-native-tvos@0.86-stable",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@react-native-tvos/config-tv": "^0.1.6",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-native": "$react-native",
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@types/node": "^22.0.0"
  },
  "private": true
}
