{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Metro",
      "type": "shell",
      "command": "npm run start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Waiting on|Metro waiting on|Logs for your project)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Prebuild",
      "type": "npm",
      "script": "prebuild:tv",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run Apple TV",
      "type": "npm",
      "script": "ios",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Run Android TV",
      "type": "npm",
      "script": "android",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Launch Apple TV",
      "type": "npm",
      "script": "ios:no-bundler",
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo-ios",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Successfully launched|BUILD SUCCEEDED|Installing|Launching)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Launch Android TV",
      "type": "npm",
      "script": "android:no-bundler",
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo-android",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(BUILD SUCCESSFUL|Installed on|Starting: Intent)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Apple TV debug",
      "dependsOn": ["Start Metro", "Launch Apple TV"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Android TV debug",
      "dependsOn": ["Start Metro", "Launch Android TV"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Run Web",
      "type": "npm",
      "script": "web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Typecheck",
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": ["$tsc"],
      "group": "test"
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": [],
      "group": "test"
    }
  ]
}
