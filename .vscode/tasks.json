{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Metro",
      "type": "shell",
      "command": "npm run start",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Waiting on|Metro waiting on|Logs for your project)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Start Metro (plugin store)",
      "type": "shell",
      "command": "npm run start:store",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo-store",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Waiting on|Metro waiting on|Logs for your project)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Launch Apple TV",
      "type": "npm",
      "script": "ios:no-bundler",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo-ios",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Successfully launched|BUILD SUCCEEDED|Installing|Launching)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Launch Android TV",
      "type": "npm",
      "script": "android:no-bundler",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo-android",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(BUILD SUCCESSFUL|Installed on|Starting: Intent)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Launch both TVs",
      "dependsOn": ["Launch Apple TV", "Launch Android TV"],
      "dependsOrder": "parallel",
      "hide": true,
      "problemMatcher": []
    },
    {
      "label": "Prebuild",
      "type": "npm",
      "script": "prebuild:tv",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run",
      "dependsOn": ["Start Metro", "Launch both TVs"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run (plugin store)",
      "dependsOn": ["Start Metro (plugin store)", "Launch both TVs"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
