{
  "cli": {
    "version": ">= 3.15.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true,
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    },
    "development_tv": {
      "extends": "development",
      "env": {
        "EXPO_TV": "1"
      }
    },
    "preview": {
      "extends": "production",
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      }
    },
    "preview_tv": {
      "extends": "preview",
      "env": {
        "EXPO_TV": "1"
      },
      "android": {
        "distribution": "internal",
        "buildType": "apk",
        "withoutCredentials": true
      },
      "ios": {
        "simulator": false,
        "distribution": "store"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store"
    },
    "production_tv": {
      "extends": "production",
      "env": {
        "EXPO_TV": "1"
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "staging_tv": {
      "extends": "production_tv",
      "channel": "staging",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "staging": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed"
      },
      "ios": {
        "ascAppId": "6791784830"
      }
    },
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "ascAppId": "6791784830"
      }
    }
  }
}
